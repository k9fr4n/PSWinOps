    <!-- PSWinOps.PublicIPAddress                                      -->
    <!-- Used by: Get-PublicIPAddress                                  -->
    <!-- ============================================================ -->
    <View>
      <Name>PSWinOps.PublicIPAddress</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.PublicIPAddress</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <AutoSize />
        <TableHeaders>
          <TableColumnHeader>
            <Label>ComputerName</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>IPv4Address</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>IPv6Address</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Provider</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Timestamp</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>ComputerName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.IPv4Address) { $_.IPv4Address } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.IPv6Address) { $_.IPv6Address } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Provider</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  if ($_.Timestamp -is [datetime]) { $_.Timestamp.ToString('yyyy-MM-dd HH:mm:ss') } else { $_.Timestamp }
                </ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>
    <!-- ============================================================ -->
    <!-- PSWinOps.NetworkRoute                                        -->
    <!-- Used by: Get-NetworkRoute, New-NetworkRoute, Set-NetworkRoute -->
    <!-- ============================================================ -->
    <View>
      <Name>PSWinOps.NetworkRoute</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.NetworkRoute</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <AutoSize />
        <TableHeaders>
          <TableColumnHeader>
            <Label>ComputerName</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>DestinationPrefix</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>NextHop</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>InterfaceAlias</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>IfIndex</Label>
            <Alignment>Right</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Metric</Label>
            <Alignment>Right</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>AF</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Protocol</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>ComputerName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>DestinationPrefix</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.NextHop -eq '0.0.0.0' -or $_.NextHop -eq '::') { 'On-link' } else { $_.NextHop }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>InterfaceAlias</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>InterfaceIndex</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>RouteMetric</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>AddressFamily</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Protocol</PropertyName>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>
