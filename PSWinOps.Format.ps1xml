              <TableColumnItem><PropertyName>TcpEstablished</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>TcpListening</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>TcpTimeWait</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>TcpCloseWait</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>TcpOther</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>UdpEndpoints</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>TotalConnections</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
