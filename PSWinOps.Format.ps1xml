          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Node</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>NodeState</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Nodes</Label>
            <Alignment>Right</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Resources</Label>
            <Alignment>Right</Alignment>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Witness</Label>
          </TableColumnHeader>
          <TableColumnHeader>
            <Label>Health</Label>
          </TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem>
                <PropertyName>ComputerName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>ClusterName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>NodeName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>NodeState</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>'{0}/{1}' -f $_.NodesUp, $_.TotalNodes</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>'{0}/{1}' -f $_.ResourcesOnline, $_.TotalResources</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.WitnessType -eq 'None') { 'None' } else { '{0} ({1})' -f $_.WitnessName, $_.WitnessState }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>OverallHealth</PropertyName>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>
