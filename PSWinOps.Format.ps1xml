              <TableColumnItem>
                <ScriptBlock>if ($_.LockoutTime) { $_.LockoutTime.ToString('yyyy-MM-dd HH:mm:ss') } else { '' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem><PropertyName>BadLogonCount</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.LastBadPasswordAttempt) { $_.LastBadPasswordAttempt.ToString('yyyy-MM-dd HH:mm:ss') } else { '' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem><PropertyName>DistinguishedName</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
