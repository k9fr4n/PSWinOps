                <PropertyName>ComputerName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>ProgramName</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Command</PropertyName>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>$_.Location -replace '\\SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\', '\...\WOW6432Node\' -replace '\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\', '\...\'</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <PropertyName>Scope</PropertyName>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
