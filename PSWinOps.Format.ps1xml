    <!-- ============================================================ -->
    <!-- PSWinOps.PublicIPAddress                                      -->
    <!-- Used by: Get-PublicIPAddress                                  -->
    <!-- ============================================================ -->
    <View>
      <Name>PSWinOps.PublicIPAddress</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.PublicIPAddress</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>ComputerName</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>IPv4Address</Label><Width>16</Width></TableColumnHeader>
          <TableColumnHeader><Label>IPv6Address</Label><Width>40</Width></TableColumnHeader>
          <TableColumnHeader><Label>Provider</Label><Width>14</Width></TableColumnHeader>
          <TableColumnHeader><Label>Timestamp</Label><Width>26</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>ComputerName</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.IPv4Address) { $_.IPv4Address } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.IPv6Address) { $_.IPv6Address } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem><PropertyName>Provider</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>
                  if ($_.Timestamp -is [datetime]) { $_.Timestamp.ToString('yyyy-MM-dd HH:mm:ss') } else { $_.Timestamp }
                </ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!-- ============================================================ -->
    <!-- PSWinOps.NetworkRoute                                        -->
    <!-- Used by: Get-NetworkRoute, New-NetworkRoute, Set-NetworkRoute -->
    <!-- ============================================================ -->
    <View>
      <Name>PSWinOps.NetworkRoute</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.NetworkRoute</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>ComputerName</Label><Width>15</Width></TableColumnHeader>
          <TableColumnHeader><Label>DestinationPrefix</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>NextHop</Label><Width>16</Width></TableColumnHeader>
          <TableColumnHeader><Label>InterfaceAlias</Label><Width>16</Width></TableColumnHeader>
          <TableColumnHeader><Label>IfIndex</Label><Width>7</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>Metric</Label><Width>7</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>AF</Label><Width>5</Width></TableColumnHeader>
          <TableColumnHeader><Label>Protocol</Label><Width>10</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>ComputerName</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>DestinationPrefix</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.NextHop -eq '0.0.0.0' -or $_.NextHop -eq '::') { 'On-link' } else { $_.NextHop }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem><PropertyName>InterfaceAlias</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>InterfaceIndex</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>RouteMetric</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>AddressFamily</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Protocol</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!-- ============================================================ -->
    <!-- PSWinOps.PortConnectivity                                    -->
    <!-- Used by: Test-PortConnectivity                               -->
    <!-- ============================================================ -->
    <View>
      <Name>PSWinOps.PortConnectivity</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.PortConnectivity</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>ComputerName</Label><Width>24</Width></TableColumnHeader>
          <TableColumnHeader><Label>Port</Label><Width>6</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>Proto</Label><Width>5</Width></TableColumnHeader>
          <TableColumnHeader><Label>Open</Label><Width>6</Width></TableColumnHeader>
          <TableColumnHeader><Label>ResponseMs</Label><Width>11</Width><Alignment>Right</Alignment></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>ComputerName</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Port</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Protocol</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.Open) { 'Open' } else { 'Closed' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.ResponseTimeMs) { '{0:N1}ms' -f $_.ResponseTimeMs } else { '-' }</ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!-- ============================================================ -->
    <!-- PSWinOps.DnsResolution                                       -->
    <!-- Used by: Test-DNSResolution                                  -->
    <!-- ============================================================ -->
    <View>
      <Name>PSWinOps.DnsResolution</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.DnsResolution</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Name</Label><Width>28</Width></TableColumnHeader>
          <TableColumnHeader><Label>DnsServer</Label><Width>16</Width></TableColumnHeader>
          <TableColumnHeader><Label>Type</Label><Width>5</Width></TableColumnHeader>
          <TableColumnHeader><Label>Result</Label><Width>24</Width></TableColumnHeader>
          <TableColumnHeader><Label>QueryMs</Label><Width>8</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>OK</Label><Width>4</Width></TableColumnHeader>
          <TableColumnHeader><Label>Match</Label><Width>5</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>Name</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>DnsServer</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>QueryType</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.Result) { $_.Result } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.QueryTimeMs) { '{0:N1}' -f $_.QueryTimeMs } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.Success) { [char]0x2713 } else { [char]0x2717 }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($null -eq $_.Consistent) { '-' } elseif ($_.Consistent) { [char]0x2713 } else { [char]0x2717 }</ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!-- ============================================================ -->
    <!-- PSWinOps.NetworkLatency                                      -->
    <!-- Used by: Measure-NetworkLatency                              -->
    <!-- ============================================================ -->
    <View>
      <Name>PSWinOps.NetworkLatency</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.NetworkLatency</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>ComputerName</Label><Width>24</Width></TableColumnHeader>
          <TableColumnHeader><Label>IPAddress</Label><Width>16</Width></TableColumnHeader>
          <TableColumnHeader><Label>Sent</Label><Width>5</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>Recv</Label><Width>5</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>Loss%</Label><Width>6</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>Min</Label><Width>7</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>Avg</Label><Width>7</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>Max</Label><Width>7</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>Jitter</Label><Width>7</Width><Alignment>Right</Alignment></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>ComputerName</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>IPAddress</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Sent</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Received</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>'{0:N1}' -f $_.LossPercent</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($null -ne $_.MinMs) { '{0:N1}' -f $_.MinMs } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($null -ne $_.AvgMs) { '{0:N1}' -f $_.AvgMs } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($null -ne $_.MaxMs) { '{0:N1}' -f $_.MaxMs } else { '-' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($null -ne $_.JitterMs) { '{0:N1}' -f $_.JitterMs } else { '-' }</ScriptBlock>
              </TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

