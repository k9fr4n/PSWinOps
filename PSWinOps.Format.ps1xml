    <!-- ============================================================ -->
    <!-- PSWinOps.ADStaleAccount                                      -->
    <!-- Used by: Get-ADStaleAccount                                  -->
    <!-- ============================================================ -->
    <View>
      <Name>PSWinOps.ADStaleAccount</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.ADStaleAccount</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>SamAccountName</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>Type</Label><Width>8</Width></TableColumnHeader>
          <TableColumnHeader><Label>Enabled</Label><Width>7</Width></TableColumnHeader>
          <TableColumnHeader><Label>LastLogonDate</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>Days</Label><Width>6</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>DistinguishedName</Label></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>SamAccountName</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>AccountType</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Enabled</PropertyName></TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($_.LastLogonDate) { $_.LastLogonDate.ToString('yyyy-MM-dd HH:mm') } else { 'Never' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem>
                <ScriptBlock>if ($null -ne $_.DaysSinceLogon) { $_.DaysSinceLogon } else { 'N/A' }</ScriptBlock>
              </TableColumnItem>
              <TableColumnItem><PropertyName>DistinguishedName</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

