    <View>
      <Name>PSWinOps.TraceRouteHop</Name>
      <ViewSelectedBy>
        <TypeName>PSWinOps.TraceRouteHop</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>Hop</Label><Width>4</Width><Alignment>Right</Alignment></TableColumnHeader>
          <TableColumnHeader><Label>IPAddress</Label><Width>18</Width></TableColumnHeader>
          <TableColumnHeader><Label>Hostname</Label><Width>32</Width></TableColumnHeader>
